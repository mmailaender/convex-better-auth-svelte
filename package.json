{
  "name": "@mmailaender/convex-better-auth-svelte",
  "author": "Micha Mailaender",
  "version": "0.8.0",
  "bugs": {
    "url": "https://github.com/mmailaender/convex-better-auth-svelte/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmailaender/convex-better-auth-svelte.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev:frontend": "vite dev",
    "dev:backend": "npx convex dev",
    "dev": "concurrently --kill-others --prefix-colors blue,yellow --names 'svelte,convex' 'pnpm dev:frontend' 'pnpm dev:backend'",
    "build": "vite build && pnpm package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "package": "svelte-kit sync && svelte-package",
    "prepack": "pnpm package",
    "lint:package": "mkdir -p /tmp/convex-better-auth-svelte-pack && pnpm pack --pack-destination /tmp/convex-better-auth-svelte-pack && publint /tmp/convex-better-auth-svelte-pack/mmailaender-convex-better-auth-svelte-$npm_package_version.tgz",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "pnpm test:unit && pnpm test:e2e",
    "setup:test-user": "npx tsx scripts/setup-test-user.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish && git push --follow-tags"
  },
  "files": [
    "dist/svelte",
    "dist/sveltekit",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "svelte": "./dist/svelte/index.js",
  "exports": {
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "import": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit/index.d.ts",
      "import": "./dist/sveltekit/index.js",
      "default": "./dist/sveltekit/index.js"
    }
  },
  "peerDependencies": {
    "@convex-dev/better-auth": ">=0.10.10",
    "convex-svelte": ">=0.13.0",
    "better-auth": "^1.4.9",
    "convex": "^1.31.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@convex-dev/better-auth": "^0.12.2",
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "convex-svelte": "^0.13.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@vitest/browser": "^4.1.8",
    "better-auth": "1.6.15",
    "concurrently": "^10.0.3",
    "convex": "1.40.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "publint": "^0.3.21",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "keywords": [
    "svelte"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "is-network-error": "^1.3.2"
  }
}
